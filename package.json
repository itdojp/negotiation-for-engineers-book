{
  "name": "negotiation-for-engineers-book",
  "version": "1.0.0",
  "description": "技術者が持つ論理的思考力とエンジニアリング能力を、ビジネス交渉の場で最大限に活用するための実践的手法を提供する。エンジニアの思考パターンや業務フローに即した独自のアプローチを提示。",
  "main": "index.md",
  "scripts": {
    "start": "jekyll serve --source docs --destination _site --livereload",
    "build": "npm run render:diagrams && jekyll build --source docs --destination _site && node scripts/check-performance-roi-evidence.js --built-site _site && node scripts/check-source-notes-safety.js --built-site _site",
    "test": "npm run check:metadata && npm run test:poc-disclosure && npm run check:poc-disclosure && npm run test:performance-roi && npm run check:performance-roi && npm run test:source-notes && npm run check:source-notes && npm run test:static-diagrams && npm run check:static-diagrams && npm run check:diagrams && npm run lint && npm run check-links",
    "lint": "markdownlint 'docs/**/*.md'",
    "check-links": "python3 .github/scripts/check_internal_links.py",
    "deploy": "gh-pages -d _site",
    "check:security": "npm audit",
    "check:metadata": "node scripts/check-metadata-consistency.js",
    "test:poc-disclosure": "node scripts/check-poc-disclosure.js --self-test",
    "check:poc-disclosure": "node scripts/check-poc-disclosure.js",
    "render:diagrams": "node scripts/render-diagrams.js",
    "check:diagrams": "node scripts/render-diagrams.js --check",
    "test:static-diagrams": "node scripts/check-static-diagrams.js --self-test",
    "check:static-diagrams": "node scripts/check-static-diagrams.js",
    "test:performance-roi": "node scripts/check-performance-roi-evidence.js --self-test",
    "check:performance-roi": "node scripts/check-performance-roi-evidence.js",
    "test:source-notes": "node scripts/check-source-notes-safety.js --self-test",
    "check:source-notes": "node scripts/check-source-notes-safety.js"
  },
  "keywords": [
    "book",
    "documentation",
    "ja"
  ],
  "author": "ITDO Inc.",
  "license": "CC-BY-NC-SA-4.0",
  "engines": {
    "node": "^22.22.2 || ^24.15.0 || >=26.0.0"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "11.16.0",
    "gh-pages": "^6.3.0",
    "markdown-link-check": "^3.14.2",
    "markdownlint-cli": "^0.49.1",
    "puppeteer": "24.43.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/itdojp/negotiation-for-engineers-book.git"
  },
  "bugs": {
    "url": "https://github.com/itdojp/negotiation-for-engineers-book/issues"
  },
  "homepage": "https://itdojp.github.io/negotiation-for-engineers-book/",
  "overrides": {
    "undici": "7.28.0",
    "cheerio": {
      "encoding-sniffer": "1.0.2"
    }
  },
  "allowScripts": {
    "puppeteer@24.43.1": true
  }
}
